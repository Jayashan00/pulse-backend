generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique
  email       String   @unique
  username    String   @unique @db.VarChar(30)
  displayName String?  @db.VarChar(60)
  bio         String?  @db.VarChar(200)
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts         Post[]
  comments      Comment[]
  likes         Like[]
  saves         Save[]
  notifications Notification[] @relation("recipient")
  actorNotifs   Notification[] @relation("actor")
  sentMessages  Message[]
  convosA       Conversation[] @relation("userA")
  convosB       Conversation[] @relation("userB")

  @@map("users")
}

model Post {
  id         String   @id @default(uuid())
  authorId   String
  caption    String   @db.VarChar(500)
  mediaUrl   String?
  mediaType  String?  @db.VarChar(10)
  shareCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]
  saves    Save[]

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  text      String   @db.VarChar(300)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("comments")
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("likes")
}

model Save {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("saves")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  actorId   String?
  type      String   @db.VarChar(20)
  message   String   @db.VarChar(200)
  postId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation("recipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("actor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@map("notifications")
}

model Conversation {
  id        String   @id @default(uuid())
  userAId   String
  userBId   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  userA    User      @relation("userA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User      @relation("userB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userAId, userBId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  text           String   @db.VarChar(1000)
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}
